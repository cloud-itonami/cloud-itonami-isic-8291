{:paths ["src"]
 ;; langgraph-clj brings langchain-clj transitively (both zero-/single-dep,
 ;; all .cljc → portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the com-junkawasaki org of this workspace.
 ;;
 ;; http-kit + jsonista (ADR-2607110400 addendum 5, dossier.companies-house)
 ;; power the ONE live-data seam this actor has (UK Companies House) —
 ;; the same JVM host-fn pair kotoba-lang/langchain's langchain.jvm already
 ;; uses for the same reason (langchain-clj's pure core stays zero-dep; a
 ;; real consuming actor like this one brings its own HTTP stack).
 :deps {io.github.com-junkawasaki/langgraph-clj
        {:local/root "../../com-junkawasaki/langgraph-clj"}
        http-kit/http-kit {:mvn/version "2.8.0"}
        metosin/jsonista  {:mvn/version "0.3.11"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain-clj to local checkout
  :dev {:override-deps
        {io.github.com-junkawasaki/langchain-clj
         {:local/root "../../com-junkawasaki/langchain-clj"}}}
  ;; clojure -M:dev:run  → drive the demo through one OperationActor
  :run {:main-opts ["-m" "dossier.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis — clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
